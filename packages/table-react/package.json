{
  "name": "@softium/table-react",
  "version": "0.1.1",
  "description": "React bindings for softium-ui Table: useTable hook, styled components, i18n.",
  "license": "MIT",
  "author": "Sunghoon Lee",
  "homepage": "https://github.com/HOONY-LEE/softium-ui/tree/main/packages/table-react#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/HOONY-LEE/softium-ui.git",
    "directory": "packages/table-react"
  },
  "bugs": {
    "url": "https://github.com/HOONY-LEE/softium-ui/issues"
  },
  "keywords": ["table", "datagrid", "react", "spreadsheet", "erp", "softium-ui"],
  "type": "module",
  "sideEffects": false,
  "files": ["dist", "LICENSE"],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "scripts": {
    "build": "tsup && node ../../scripts/add-use-client.mjs dist/index.js dist/index.cjs",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@softium/table-core": "workspace:*",
    "lucide-react": "^0.460.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tsup": "^8.3.5",
    "typescript": "^5.7.3",
    "vitest": "^2.1.8"
  },
  "publishConfig": {
    "access": "public"
  }
}
