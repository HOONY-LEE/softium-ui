{
  "name": "@softium/table-core",
  "version": "0.1.0",
  "description": "Headless core for softium-ui Table. Types, adapters, and derivation logic. No DOM.",
  "license": "MIT",
  "author": "Sunghoon Lee",
  "homepage": "https://github.com/HOONY-LEE/softium-ui/tree/main/packages/table-core#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/HOONY-LEE/softium-ui.git",
    "directory": "packages/table-core"
  },
  "bugs": {
    "url": "https://github.com/HOONY-LEE/softium-ui/issues"
  },
  "keywords": ["table", "datagrid", "headless", "erp", "typescript", "softium-ui"],
  "type": "module",
  "sideEffects": false,
  "files": ["dist", "LICENSE"],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests"
  },
  "devDependencies": {
    "tsup": "^8.3.5",
    "typescript": "^5.7.3",
    "vitest": "^2.1.8"
  },
  "publishConfig": {
    "access": "public"
  }
}
